.event-card {
  display: flex;
  flex-direction: column;
  height: 100%;
  width: 380px;
  max-width: 90vw;
  position: fixed;
  top: 0;
  right: 0;
  z-index: 500;
  background: #faf8f2;
  color: #3d3229;
  font-family: 'Noto Sans TC', sans-serif;
  border-left: 1px solid #d4c9b8;
  box-shadow: -4px 0 20px rgba(0, 0, 0, 0.1);
  animation: slideIn 0.3s ease-out;
}

@keyframes slideIn {
  from { transform: translateX(100%); }
  to { transform: translateX(0); }
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.drag-handle {
  display: none;
  width: 40px;
  height: 4px;
  background: #d4c9b8;
  border-radius: 2px;
  margin: 10px auto 0;
  flex-shrink: 0;
}

@media (max-width: 480px) {
  .event-card {
    top: auto;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    max-width: 100%;
    height: 62vh;
    border-left: none;
    border-top: 1px solid #d4c9b8;
    border-radius: 16px 16px 0 0;
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.12);
    animation: slideUp 0.3s ease-out;
  }

  .drag-handle {
    display: block;
  }

  .card-header {
    padding: 12px 16px;
  }

  .card-body {
    padding: 0 16px 16px;
  }
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20px;
  background: linear-gradient(135deg, #f0e8d8, #e8dfcc);
  border-bottom: 2px solid #d4c9b8;
}

.header-left {
  flex: 1;
}

.dynasty-badge {
  display: inline-block;
  background: #8b7355;
  color: #fff;
  font-size: 0.75rem;
  padding: 2px 10px;
  border-radius: 3px;
  margin-bottom: 8px;
  letter-spacing: 1px;
}

.header-left h3 {
  margin: 0;
  font-family: 'Noto Serif TC', serif;
  font-size: 1.4rem;
  font-weight: 700;
  color: #2c241b;
  line-height: 1.3;
}

.close-btn {
  background: none;
  border: 1px solid #d4c9b8;
  color: #8b7355;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  cursor: pointer;
  font-size: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.close-btn:hover {
  background: #d4c9b8;
  color: #2c241b;
}

.card-meta {
  display: flex;
  gap: 16px;
  padding: 12px 20px;
  background: #f5f0e8;
  font-size: 0.85rem;
  color: #665a4a;
  border-bottom: 1px solid #e0d8cc;
}

.card-meta .year {
  font-weight: 600;
}

.card-meta .location {
  color: #8b7355;
}

.card-body {
  flex: 1;
  overflow-y: auto;
  padding: 0 20px 20px;
}

.section {
  margin-top: 20px;
}

.section h4 {
  margin: 0 0 10px;
  font-family: 'Noto Serif TC', serif;
  font-size: 1rem;
  font-weight: 600;
  color: #8b7355;
  border-left: 3px solid #c8a427;
  padding-left: 10px;
}

.section p {
  margin: 0;
  line-height: 1.7;
  font-size: 0.92rem;
  text-align: justify;
  color: #4a3d32;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag {
  background: #f0e8d8;
  border: 1px solid #d4c9b8;
  padding: 4px 12px;
  border-radius: 4px;
  font-size: 0.85rem;
  color: #4a3d32;
}

.exam-section,
.related-section,
.quiz-section {
  margin-top: 24px;
  padding-top: 16px;
  border-top: 1px dashed #d4c9b8;
}

.exam-item {
  margin-bottom: 8px;
  font-size: 0.88rem;
}

.exam-label {
  color: #8b7355;
  font-weight: 500;
}

.exam-value {
  color: #2c241b;
}

.importance-high { color: #c41e3a; }
.importance-medium { color: #c8a427; }
.importance-low { color: #8b7355; }

.related-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.related-item {
  padding: 10px 12px;
  background: #fcfbf9;
  border: 1px solid #e8e0d5;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.2s;
}

.related-item:hover {
  background: #f0e8d8;
  border-color: #c8a427;
  transform: translateX(4px);
}

.rel-title {
  font-weight: 600;
  color: #2c241b;
  font-size: 0.9rem;
}

.quiz-question {
  margin-bottom: 16px;
}

.quiz-prompt {
  margin: 0 0 8px;
  font-size: 0.9rem;
  font-weight: 500;
  color: #2c241b;
}

.quiz-options {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.quiz-option {
  text-align: left;
  padding: 8px 12px;
  background: #fcfbf9;
  border: 1px solid #e8e0d5;
  border-radius: 6px;
  font-size: 0.85rem;
  color: #3d3229;
  cursor: pointer;
  transition: all 0.15s;
  font-family: inherit;
}

.quiz-option:hover:not(.correct):not(.wrong) {
  background: #f0e8d8;
  border-color: #c8a427;
}

.quiz-option.selected:not(.correct):not(.wrong) {
  background: rgba(139, 115, 85, 0.12);
  border-color: #8b7355;
  font-weight: 500;
}

.quiz-option.correct {
  background: rgba(46, 125, 50, 0.1);
  border-color: #2e7d32;
  color: #2e7d32;
}

.quiz-option.wrong {
  background: rgba(196, 30, 58, 0.08);
  border-color: #c41e3a;
  color: #c41e3a;
}

.quiz-footer {
  margin-top: 16px;
  text-align: center;
}

.submit-btn {
  padding: 10px 32px;
  background: #8b7355;
  color: #fff;
  border: none;
  border-radius: 6px;
  font-size: 0.9rem;
  font-family: 'Noto Sans TC', sans-serif;
  cursor: pointer;
  transition: background 0.15s;
}

.submit-btn:hover:not(:disabled) {
  background: #6d5a40;
}

.submit-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.quiz-result {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16px;
  padding: 12px;
  background: #f5f0e8;
  border-radius: 6px;
  border: 1px solid #e0d8cc;
}

.result-badge {
  font-size: 0.9rem;
  font-weight: 600;
}

.result-badge.pass {
  color: #2e7d32;
}

.result-badge.fail {
  color: #c41e3a;
}

.retry-btn {
  padding: 6px 16px;
  background: none;
  border: 1px solid #8b7355;
  color: #8b7355;
  border-radius: 4px;
  font-size: 0.8rem;
  cursor: pointer;
  font-family: inherit;
  transition: all 0.15s;
}

.retry-btn:hover {
  background: #8b7355;
  color: #fff;
}