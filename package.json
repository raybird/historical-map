{
  "name": "historical-map-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build:schematics": "schematics/node_modules/.bin/tsc -p schematics/tsconfig.json && npm run copy:templates",
    "copy:templates": "node schematics/scripts/copy-templates.mjs",
    "test:schematics": "npm run build:schematics && schematics/node_modules/.bin/jasmine --config=schematics/jasmine.json",
    "verify": "node scripts/verify-ng-add.mjs"
  }
}
